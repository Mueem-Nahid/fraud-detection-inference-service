# ModelServe environment template. Copy to .env for local overrides.

# FastAPI / MLflow
MODEL_NAME=fraud_detection_model
MODEL_STAGE=Production
MLFLOW_TRACKING_URI=http://mlflow:5000

# Feast / Redis
FEAST_REPO_PATH=/app/feast_repo
REDIS_HOST=redis
REDIS_PORT=6379

# PostgreSQL backing MLflow
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=mlflow
POSTGRES_PASSWORD=mlflow_password
POSTGRES_DB=mlflow

# MLflow artifacts. Use a local path for Compose and s3://... in AWS.
MLFLOW_BACKEND_STORE_URI=postgresql://mlflow:mlflow_password@postgres:5432/mlflow
MLFLOW_DEFAULT_ARTIFACT_ROOT=/mlflow/artifacts
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=replace-me
AWS_SECRET_ACCESS_KEY=replace-me
MLFLOW_S3_ENDPOINT_URL=

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin123
GF_USERS_ALLOW_SIGN_UP=false
